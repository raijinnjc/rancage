# RANCAGE DSS - Environment Variable Configurations Example
# Define credentials here. Copy this file to .env before starting the server.

# Server Configuration Port
PORT=3000

# Server Secret Key for session signing
SESSION_SECRET=rancage_state_secret_hash_key_2026

# Google Gemini API key for Policy recommendation models and Natural Language summaries
GEMINI_API_KEY=

# Database Connection URI (Prisma / PostgreSQL)
DATABASE_URL=postgresql://rancage_db_admin:secure_password_here@localhost:5432/rancage_dss?schema=public

# Auditing and logging levels (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO
